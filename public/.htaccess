<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. EXCLUDE SEO FILES FROM REACT ROUTING
  # This tells the server: "If the file exists, just show it and STOP here"
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^(sitemap\.xml|robots\.txt)$ - [L]

  # 2. STANDARD REACT ROUTING
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
