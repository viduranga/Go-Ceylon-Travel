<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Specific rule for SEO files
  RewriteRule ^(sitemap\.xml|robots\.txt)$ - [L]

  RewriteRule ^index\.html$ - [L]
  
  # This tells the server: "If the file doesn't exist, use index.html"
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # ADD THIS LINE to prevent the app from "eating" your XML files
  RewriteCond %{REQUEST_URI} !^/(sitemap\.xml|robots\.txt)
  
  RewriteRule . /index.html [L]
</IfModule>
