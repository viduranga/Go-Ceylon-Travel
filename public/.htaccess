<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # --- ADD THESE TWO LINES ---
  RewriteRule ^sitemap\.xml$ sitemap.xml [L]
  RewriteRule ^robots\.txt$ robots.txt [L]
  # ---------------------------

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>