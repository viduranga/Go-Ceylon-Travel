{
  "entities": {
    "Review": {
      "title": "Review",
      "description": "A review submitted by a guest on the website.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the guest." },
        "location": { "type": "string", "description": "The location of the guest." },
        "rating": { "type": "number", "description": "The star rating (1-5)." },
        "comment": { "type": "string", "description": "The review text." },
        "date": { "type": "string", "description": "The date the review was submitted." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp for sorting." }
      },
      "required": ["name", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of guest reviews submitted directly on the website."
    }
  }
}
